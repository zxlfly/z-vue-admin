{
    "name": "vue-admin",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
        "lint:eslint": "eslint src/**/{*.vue,*.js,*.ts,*.jsx,*.tsx} --cache --fix",
        "format": "prettier --write \"./**/*.{html,vue,ts,js,json}\"",
        "lint:css": "stylelint src/**/*.{vue,css,sass,scss} --cache --fix"
    },
    "dependencies": {
        "@element-plus/icons-vue": "^2.1.0",
        "axios": "^1.5.1",
        "dayjs": "^1.11.10",
        "element-plus": "^2.3.14",
        "highcharts": "^11.1.0",
        "lodash-es": "^4.17.21",
        "nprogress": "^0.2.0",
        "pinia": "^2.1.6",
        "tui-calendar-hi": "1.15.1-5",
        "vue": "^3.3.4",
        "vue-router": "^4.2.4",
        "windicss": "^3.5.6"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.22.15",
        "@commitlint/cli": "^17.7.2",
        "@commitlint/config-conventional": "^17.7.0",
        "@tsconfig/node18": "^18.2.2",
        "@types/lodash-es": "^4.17.9",
        "@types/node": "^18.17.17",
        "@typescript-eslint/eslint-plugin": "^6.7.5",
        "@typescript-eslint/parser": "^6.7.5",
        "@vitejs/plugin-vue": "^4.3.4",
        "@vitejs/plugin-vue-jsx": "^3.0.2",
        "@vue/tsconfig": "^0.4.0",
        "eslint": "^8.51.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-import": "^2.28.1",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.0.1",
        "eslint-plugin-vue": "^9.17.0",
        "husky": "^8.0.3",
        "lint-staged": "^14.0.1",
        "mockjs": "^1.1.0",
        "npm-run-all2": "^6.0.6",
        "prettier": "^3.0.3",
        "sass": "^1.69.2",
        "stylelint": "^15.10.3",
        "stylelint-config-recommended-vue": "^1.5.0",
        "stylelint-config-standard": "^34.0.0",
        "stylelint-config-standard-scss": "^11.0.0",
        "stylelint-scss": "^5.2.1",
        "typescript": "~5.2.0",
        "unplugin-auto-import": "^0.16.6",
        "unplugin-icons": "^0.17.0",
        "unplugin-vue-components": "^0.25.2",
        "vite": "^4.4.9",
        "vite-plugin-mock": "^3.0.0",
        "vite-plugin-svg-icons": "^2.0.1",
        "vite-plugin-vue-setup-extend-plus": "^0.1.0",
        "vite-plugin-windicss": "^1.9.1",
        "vue-i18n": "^9.5.0",
        "vue-tsc": "^1.8.11"
    },
    "lint-staged": {
        "src/**/{*.vue,*.js,*.ts,*.jsx,*.tsx}": "eslint --fix",
        "src/**/{*.vue,*.scss,*.sass,*.css}": "stylelint --fix"
    }
}
