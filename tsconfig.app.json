{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": [
        "types/**.d.ts",
        "types/**/*.d.ts",
        "src/**/*.ts",
        "src/**/*.vue"
    ],
    "exclude": ["src/**/__tests__/*"],
    "compilerOptions": {
        "composite": true,
        "allowJs":true,
        "moduleResolution": "node",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["element-plus/global", "unplugin-icons/types/vue"]
    }
}
